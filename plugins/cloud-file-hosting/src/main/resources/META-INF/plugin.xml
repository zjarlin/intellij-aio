<idea-plugin>
    <id>site.addzero.cloudfile</id>
    <name>Cloud File Hosting</name>
    <vendor email="zjarlin@outlook.com" url="https://gitee.com/zjarlin">zjarlin</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Application Level Settings -->
        <applicationService serviceImplementation="site.addzero.cloudfile.settings.CloudFileSettings"/>
        <applicationConfigurable instance="site.addzero.cloudfile.settings.CloudFileConfigurable" displayName="Cloud File Hosting"/>

        <!-- Project Level Settings -->
        <projectService serviceImplementation="site.addzero.cloudfile.settings.ProjectHostingSettings"/>

        <!-- Project Services -->
        <projectService serviceInterface="site.addzero.cloudfile.sync.CloudFileSyncService"
                        serviceImplementation="site.addzero.cloudfile.sync.CloudFileSyncService"/>
        <projectService serviceInterface="site.addzero.cloudfile.git.GitIntegrationService"
                        serviceImplementation="site.addzero.cloudfile.git.GitIntegrationService"/>
        <projectService serviceInterface="site.addzero.cloudfile.cache.OfflineCacheManager"
                        serviceImplementation="site.addzero.cloudfile.cache.OfflineCacheManager"/>
        <projectService serviceInterface="site.addzero.cloudfile.share.ShareLinkManager"
                        serviceImplementation="site.addzero.cloudfile.share.ShareLinkManager"/>

        <!-- Startup Activity -->
        <postStartupActivity implementation="site.addzero.cloudfile.sync.CloudFileStartupActivity"/>

        <!-- File Change Listener -->
        <vfsListener implementation="site.addzero.cloudfile.sync.FileChangeListener"/>

        <!-- Tool Window -->
        <toolWindow id="Cloud Hosting"
                    anchor="right"
                    factoryClass="site.addzero.cloudfile.ui.CloudFileToolWindowFactory"
                    icon="AllIcons.Nodes.PpLibFolder"
                    secondary="false"/>

        <!-- Notification Group -->
        <notificationGroup id="CloudFile Notifications" displayType="BALLOON" isLogByDefault="true"/>

        <!-- Background Task -->
        <backgroundPostStartupActivity implementation="site.addzero.cloudfile.sync.CloudFileBackgroundSync"/>
    </extensions>

    <actions>
        <!-- Global Actions -->
        <action id="CloudFile.SyncToCloud"
                class="site.addzero.cloudfile.actions.SyncToCloudAction"
                text="Sync to Cloud"
                description="Sync selected files to cloud storage"
                icon="AllIcons.Actions.Upload">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="CloudFile.SyncFromCloud"
                class="site.addzero.cloudfile.actions.SyncFromCloudAction"
                text="Sync from Cloud (Overwrite Local)"
                description="Download files from cloud and overwrite local"
                icon="AllIcons.Actions.Download">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="CloudFile.AddToHosting"
                class="site.addzero.cloudfile.actions.AddToHostingAction"
                text="Add to Cloud Hosting"
                description="Add file to cloud hosting rules"
                icon="AllIcons.Nodes.PpLibFolder">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <action id="CloudFile.OpenSettings"
                class="site.addzero.cloudfile.actions.OpenSettingsAction"
                text="Cloud Hosting Settings"
                description="Open Cloud File Hosting settings">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
