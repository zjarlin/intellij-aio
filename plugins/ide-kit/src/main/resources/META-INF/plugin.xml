<idea-plugin>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <directoryIndexExcludePolicy implementation="site.addzero.smart.intentions.find.sourceonly.SmartGeneratedArtifactExcludePolicy"/>
        <searchScopesProvider implementation="site.addzero.smart.intentions.find.sourceonly.SmartSourceOnlySearchScopeProvider"/>
        <projectService serviceImplementation="site.addzero.smart.intentions.hiddenfiles.HiddenFilesProjectService"/>
        <projectService serviceImplementation="site.addzero.smart.intentions.modulelock.ModuleLockProjectService"/>
        <projectService serviceImplementation="site.addzero.koog.agent.KoogAgentCommentGenerationService"/>
        <applicationService serviceImplementation="site.addzero.koog.agent.settings.KoogAgentSettingsService"/>
        <treeStructureProvider implementation="site.addzero.smart.intentions.hiddenfiles.HiddenFilesTreeStructureProvider"/>
        <ignoredFileProvider implementation="site.addzero.smart.intentions.hiddenfiles.HiddenFilesIgnoredFileProvider"/>
        <notificationGroup id="IdeKit Notifications" displayType="BALLOON" isLogByDefault="true"/>
        <applicationConfigurable
                parentId="tools"
                instance="site.addzero.koog.agent.settings.KoogAgentConfigurable"
                id="site.addzero.koog.agent.settings"
                displayName="ide-kit AI"/>
        <postStartupActivity implementation="site.addzero.koog.agent.KoogAgentProjectActivity"/>

        <intentionAction order="FIRST">
            <className>site.addzero.koog.agent.KoogAgentGenerateCodeIntention</className>
            <category>ide-kit</category>
        </intentionAction>

        <intentionAction order="FIRST">
            <language>kotlin</language>
            <className>site.addzero.smart.intentions.kotlin.classtointerface.SmartConvertClassToInterfaceIntention</className>
            <category>Smart Intentions</category>
        </intentionAction>

        <intentionAction order="FIRST">
            <language>kotlin</language>
            <className>site.addzero.smart.intentions.kotlin.redundantexplicittype.SmartRemoveRedundantExplicitTypeIntention</className>
            <category>Smart Intentions</category>
        </intentionAction>

        <intentionAction order="FIRST">
            <language>kotlin</language>
            <className>site.addzero.smart.intentions.kotlin.redundantexplicittype.SmartRemoveProjectRedundantExplicitTypeIntention</className>
            <category>Smart Intentions</category>
        </intentionAction>

        <intentionAction order="FIRST">
            <language>kotlin</language>
            <className>site.addzero.smart.intentions.kotlin.shortenqualifiedname.SmartShortenProjectQualifiedNamesIntention</className>
            <category>Smart Intentions</category>
        </intentionAction>

        <localInspection
                language="kotlin"
                shortName="SmartRedundantExplicitType"
                displayName="冗余的显式类型声明"
                groupName="Smart Intentions"
                enabledByDefault="true"
                level="WEAK WARNING"
                implementationClass="site.addzero.smart.intentions.kotlin.redundantexplicittype.SmartRedundantExplicitTypeInspection"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <actions>
        <action id="IdeKit.RunTarget.LocateCurrent"
                class="site.addzero.smart.intentions.actions.LocateCurrentRunTargetAction">
            <add-to-group group-id="GoToMenu" anchor="last"/>
            <add-to-group group-id="MainToolbarRight" anchor="before" relative-to-action="HelpTopics"/>
        </action>
        <action id="IdeKit.Kotlin.ShortenProjectQualifiedNames"
                class="site.addzero.smart.intentions.kotlin.shortenqualifiedname.ShortenProjectQualifiedNamesAction">
            <add-to-group group-id="CodeMenu" anchor="last"/>
        </action>
        <action id="IdeKit.HiddenFiles.Hide"
                class="site.addzero.smart.intentions.hiddenfiles.actions.HideFilesAction">
            <add-to-group group-id="ProjectViewPopupMenuModifyGroup" anchor="last"/>
        </action>
        <action id="IdeKit.HiddenFiles.Unhide"
                class="site.addzero.smart.intentions.hiddenfiles.actions.UnhideFilesAction">
            <add-to-group group-id="ProjectViewPopupMenuModifyGroup" anchor="last"/>
        </action>
        <action id="IdeKit.HiddenFiles.ToggleShow"
                class="site.addzero.smart.intentions.hiddenfiles.actions.ToggleShowHiddenFilesAction">
            <add-to-group group-id="ProjectViewToolbar" anchor="before" relative-to-action="NewElement"/>
        </action>
        <action id="IdeKit.ModuleLock.Lock"
                class="site.addzero.smart.intentions.modulelock.actions.LockModuleAction">
            <add-to-group group-id="ProjectViewPopupMenuModifyGroup" anchor="last"/>
        </action>
        <action id="IdeKit.ModuleLock.Unlock"
                class="site.addzero.smart.intentions.modulelock.actions.UnlockModuleAction">
            <add-to-group group-id="ProjectViewPopupMenuModifyGroup" anchor="last"/>
        </action>
        <action id="IdeKit.ModuleLock.ToggleShow"
                class="site.addzero.smart.intentions.modulelock.actions.ToggleShowLockedModulesAction">
            <add-to-group group-id="ProjectViewToolbar" anchor="before" relative-to-action="IdeKit.HiddenFiles.ToggleShow"/>
        </action>
    </actions>
</idea-plugin>
