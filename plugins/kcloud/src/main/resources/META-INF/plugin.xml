<idea-plugin>
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
            parentId="tools"
            instance="site.addzero.kcloud.idea.configcenter.KCloudConfigCenterAppConfigurable"
            id="site.addzero.kcloud.settings"
            displayName="KCloud Config Center"/>

        <projectConfigurable
            parentId="tools"
            instance="site.addzero.kcloud.idea.configcenter.KCloudConfigCenterProjectConfigurable"
            id="site.addzero.kcloud.project.settings"
            displayName="KCloud Config Center"/>

        <toolWindow
            id="KCloud Config"
            anchor="right"
            factoryClass="site.addzero.kcloud.idea.configcenter.KCloudConfigCenterToolWindowFactory"
            icon="AllIcons.General.Settings"/>

        <notificationGroup
            id="KCloud Config Center"
            displayType="BALLOON"
            isLogByDefault="true"/>

        <codeInsight.lineMarkerProvider
            language="kotlin"
            implementationClass="site.addzero.kcloud.idea.ControllerApiSourceLineMarkerProvider"/>

        <intentionAction order="FIRST">
            <language>kotlin</language>
            <className>site.addzero.kcloud.idea.configcenter.KCloudExtractLiteralToConfigIntention</className>
            <category>kcloud</category>
        </intentionAction>

        <intentionAction order="FIRST">
            <language>kotlin</language>
            <className>site.addzero.kcloud.idea.configcenter.KCloudReplaceLocalEndpointIntention</className>
            <category>kcloud</category>
        </intentionAction>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
</idea-plugin>
