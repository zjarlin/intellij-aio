<idea-plugin>
    <id>site.addzero.problem4ai</id>

    <name>Problem4AI</name>
    <vendor email="zjarlin@outlook.com" url="https://gitee.com/zjarlin/autoddl-idea-plugin.git">zjarlin</vendor>

    <description><![CDATA[
        Problem4AI is an IntelliJ IDEA plugin that automatically collects compilation errors and warnings from your project, and generates AI-friendly prompts for quick fixes.
        <h2>Features</h2>
        <ul>
            <li>Automatically collect project compilation errors and warnings</li>
            <li>Categorized display (Errors/Warnings)</li>
            <li>Click to navigate to problem location</li>
            <li>One-click copy to generate AI fix prompts</li>
            <li>Integrated into IDE Problems panel</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- 项目启动时注入到 Problems 面板 -->
        <postStartupActivity implementation="site.addzero.diagnostic.problemsview.AiFixProblemsInjector"/>

        <!-- 项目启动时触发全局诊断扫描（饿汉式） -->
        <postStartupActivity implementation="site.addzero.diagnostic.service.GlobalDiagnosticCacheInitializer"/>

        <!-- 项目启动时初始化MCP服务 -->
        <postStartupActivity implementation="site.addzero.diagnostic.mcp.DiagnosticMcpInitializer"/>

        <!-- 通知组 -->
        <notificationGroup id="Problem4AI Notifications" displayType="BALLOON" isLogByDefault="true"/>

        <!-- 项目级服务 -->
        <projectService
                serviceImplementation="site.addzero.diagnostic.config.DiagnosticExclusionConfig"/>
        <projectService
                serviceImplementation="site.addzero.diagnostic.service.DiagnosticCollectorService"/>
        <projectService
                serviceImplementation="site.addzero.diagnostic.service.GlobalDiagnosticCache"/>
        <projectService
                serviceImplementation="site.addzero.diagnostic.mcp.DiagnosticMcpServer"/>
    </extensions>
</idea-plugin>
